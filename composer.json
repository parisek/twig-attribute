{
    "name": "parisek/twig-attribute",
    "description": "A Twig extension for adding attributes to an element",
    "keywords": ["twig", "attribute"],
    "homepage": "https://github.com/parisek/twig-attribute",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^7.4 || ^8.0",
        "drupal/core-render": "^10.0 || ^11.0",
        "drupal/core-utility": "^10.0 || ^11.0",
        "twig/twig": "^2.4 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Drupal\\Component\\Attribute\\": "src",
            "Parisek\\Twig\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Parisek\\Twig\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=PSR12 src/ AttributeExtension.php",
        "phpstan": "phpstan analyse src/ AttributeExtension.php --level=5"
    }
}
